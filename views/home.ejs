<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Same Dramas...</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        @font-face {
          font-family: 'Olive Village';
          src: url('./Ponari-Jpw1j.ttf') format('truetype');
        }
      
        .olive-village-heading {
      font-family: 'Olive Village', sans-serif;
    }
      </style>
</head>
<body>
    <header class="header" style="margin: 0;">
        <!-- <h1>Same Dramas...</h1> -->
        <h1 class="olive-village-heading">Same Dramas</h1>
        <form action="/movie" method="post">
            <input name="moviename" type="text" placeholder="Search for movies" class="search-bar">
            <button class="btn"><i class="fa-solid fa-magnifying-glass"></i></button>
        </form>
        <form action="/moremovies" method="post">
            <button class="btn" >more</button>
        </form>
    </header>
    <div class="searchh "  id="transition-gradient">
        <div id="mno" class="card pulse-glow" style="width: 19rem; height: 25rem; box-shadow: 0px 4px 8px 0px rgba(0, 0, 0, 0.2); width: fit-content; border-radius: 5% 5% 0 0 ">
            
            <img src="https://th.bing.com/th/id/OIP.GPFEY6kfgxbsja6gmrW6rwAAAA?rs=1&pid=ImgDetMain" class="card-img-top" alt="..." style="width: 19rem; height: 50%; border-radius: 5% 5% 0 0" >
            
            <div class="card-body" style="padding: 0 1rem 0 1rem;" >
                <h3 class="card-title">TITTLE</h3>
            </div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item">An item</li>
                <li class="list-group-item">A second item</li>
                <li class="list-group-item">A third item</li>
            </ul>
            <div class="card-body" style="padding: 0 1rem 0 1rem;">
                <a href="#" class="card-link" style="text-decoration: none;">Card link</a>
                <a href="#" class="card-link" style="text-decoration: none;">Another link</a>
            </div>
        
        </div>
    </div>

    <div class="recomm">
        <h3 style="justify-content: center;">I hope u like the below content</h3>
    <main class="movie-container" style="display: flex; flex-wrap: wrap; justify-content: center;" >
        <% for(let movie of movies) { %>
            <div class="card" style="width: 19rem; height: 25rem; box-shadow: 0px 4px 8px 0px rgba(0, 0, 0, 0.2); width: fit-content; border-radius: 5% 5% 0 0 ">
                <img src=<%= movie.img %> class="card-img-top" alt="..." style="width: 19rem; height: 50%; border-radius: 5% 5% 0 0" >
                <div class="card-body" style="padding: 0 1rem 0 1rem;" >
                    <h3 class="card-title"> <%= movie.title %></h3>
                </div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">An item</li>
                    <li class="list-group-item">A second item</li>
                    <li class="list-group-item">A third item</li>
                </ul>
                <div class="card-body" style="padding: 0 1rem 0 1rem;">
                    <a href="#" class="card-link">Card link</a>
                    <a href="#" class="card-link">Another link</a>
                </div>
            </div>
        <% } %>
        </div>
    </main>

    <footer class="footer">
        &copy; 2024 Movie Recommendations
    </footer>
</body>
</html>